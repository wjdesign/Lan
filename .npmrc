# pnpm config

# Peer deps: don't fail CI on peer warnings (some Nuxt modules pin loosely)
strict-peer-dependencies=false

# Whitelist native packages whose install scripts must run.
# Must mirror package.json#pnpm.onlyBuiltDependencies.
# pnpm 11 requires this in .npmrc for the deps-status-check that runs before
# each script (e.g. `pnpm generate`), since the auto-triggered install does
# not always read package.json's pnpm field.
only-built-dependencies[]=@parcel/watcher
only-built-dependencies[]=better-sqlite3
only-built-dependencies[]=esbuild
only-built-dependencies[]=sharp
only-built-dependencies[]=unrs-resolver
only-built-dependencies[]=vue-demi
